.too-login-button
  &.logged
    .user-login-title
      display none
    .user-logged-title
      display block

  .user-login-title, .user-logged-title
    button()
    padding 2px 6px
    get-font-size(small)
    .too-mobile-menu &
      get-font-size(large)


  .user-logged-title
    display none
    &:after
      content '\25BC'
      padding 0 0 0 4px
      margin-left 4px


.too-login-forms
  display none
  greyout()
  &.open
    display flex
    .user-login-form
      display block
    .user-logged-form
      display none
    &.logged
      .user-login-form
        display none
      .user-logged-form
        display block


  button
    button()
  
  .user-login-close
    closecross()
    get-font-size(medium)

  .user-logged-form, .user-login-form
    dialog-box()
    display none
    min-width 250px
    padding 20px 10px
    .panel
      display flex
      flex-direction column
      gap 10px
      input, label, button
        get-font-size(medium)

  .user-logged-form
    .panel
      align-items start

      button, .user-logged-name
        align-self center

      a 
        color  $color-blue-darker
        text-decoration underline
        &:hover
          color $color-primary
      hr
        width 80%

      &.user-account-actions
        width 100%
  .user-login-form
    .panel
      align-items center

      button
        margin 20px 0

      label
        margin-top 20px
        align-self flex-start

      hr
        margin-bottom 0
        width 100%
      .hr-text-center
        margin-top -1.4em
        padding 0 5px
        background-color $color-background

      .login-oauth
        display flex
        flex-direction row
        justify-content space-around
        width 100%
        .button
          border 0
          height 50px
          svg, img
            width 100%
            height 100%

    .panel
      input
        min-width 200px

    .error-msg
      align-self flex-start
      color #e05555
      min-height 1em
      font-size 0.85em

    .forgot-password-link
      color $color-blue-darker
      text-decoration underline
      cursor pointer
      align-self flex-start
      &:hover
        color $color-primary

    .signup-panel, .forgot-panel
      display none

    &.signup
      .signup-panel
        display flex
      .login-panel
        display none

    &.forgot
      .forgot-panel
        display flex
      .login-panel
        display none

.change-action-wrapper
  position fixed
  inset 0
  display flex
  align-items center
  justify-content center
  background rgba(0,0,0,0.18)
  z-index 1200

  .change-action-card
    .change-action-form
      display flex
      flex-direction column
      gap 8px

      label
        color #222

      input
        width 100%
        padding 8px 10px
        border 1px solid rgba(0,0,0,0.12)
        border-radius 6px
        font-size 14px
        background #fff
        color #222

      .actions
        display flex
        gap 8px
        justify-content center
        margin-top 8px
        width 100%

        .button
          padding 8px 12px
          border-radius 6px
          border none
          background $color-primary
          color #fff
          cursor pointer

        .button.button-cancel
          background rgba(0,0,0,0.06)
          color #444

        .button.danger
          background #c9302c
          color #fff
        .button.danger:hover
          filter brightness(0.98)

@media (max-width:480px)
  .change-action-card
    margin 16px
    width calc(100% - 32px)
    max-width none

