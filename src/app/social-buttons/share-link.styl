.sl-overlay
  display flex
  greyout()

  .sl-dialog
    dialog-box()
    width 520px
    max-width 95%
    padding 16px
    get-font-size(small)

    .sl-close
      closecross()

    .sl-title
      margin-bottom 8px
      get-font-size(large)

    .sl-column
      margin 10px 0
      display flex
      flex-direction column

    .sl-row
      display flex
      align-items center
      gap 8px
      margin-bottom 12px
      

    .sl-base
      width 50%
      word-wrap break-word

    .sl-private-ds
      display flex
      flex-direction column
      span
        margin-top 2px
        label
          margin-left 5px

    .sl-slug-wrapper
      width 50%

    .sl-slug
      width 100%
      padding 6px 8px
      border 1px solid #ccc
      border-radius 4px

    .sl-availability
      height 0

    .sl-availability.ok
      color #008800

    .sl-availability.busy
      color #b80000

    .sl-label-wrapper
      display flex
      align-items center
      gap 6px
      width 50%

    .sl-label
      margin-bottom 0

    .sl-tooltip-trigger
      display inline-flex
      align-items center
      justify-content center
      width 18px
      height 18px
      border-radius 50%
      border 1px solid #999
      color #999
      cursor help
      position relative

      .sl-tooltip-text
        display none
        position absolute
        bottom calc(100% + 8px)
        left 50%
        transform translateX(-50%)
        width 260px
        padding 8px 10px
        background #333
        color #fff
        line-height 1.4
        border-radius 4px
        white-space normal
        z-index 10

      &:hover .sl-tooltip-text
        display block

    .sl-select
      margin-left auto
      width 50%
      padding 6px
      border 1px solid #ccc
      border-radius 4px

    .sl-actions
      display flex
      gap 12px
      margin-top 14px
      justify-content center

    .sl-btn
      button()
      get-font-size(large)

    .sl-cancel
      background none
      border 1px solid #ccc
      color #666
